# Source & config (not needed at runtime)
src/**
**/*.ts
**/*.map
**/tsconfig.json
**/eslint.config.mjs
**/.vscode-test.*

# VS Code development
.vscode/**
.vscode-test/**

# Environment files
**/.env
**/.env.*
**/.npmrc
**/.pypirc
**/.netrc
**/credentials*
**/secrets*
**/*.{pem,key,p12,pfx,jks,keystore}

# Development files
*.vsix
npm-debug.log*
yarn-debug.log*
yarn-error.log*
scripts/**
pnpm-workspace.yaml

# Build dependencies
node_modules/**
pnpm-lock.yaml
package-lock.json
yarn.lock

# Documentation & process (not needed in VSIX)
UPDATEFLOW.md
specs/**
.DS_Store
.git/**
.gitignore

# Test output
out/test/**

# pnpm local store (should never ship)
.pnpm-store/**

# Asset drafts
assets/icon-drafts/**
.github/**
.idea/**
.codex/**
coverage/**
tmp/**
temp/**
